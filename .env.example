# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/sunusante

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Email Configuration (SendGrid or AWS SES)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@sunusante.sn

# SMS Configuration (Twilio or Africa's Talking)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Africa's Talking (alternative SMS provider)
AT_API_KEY=your-africas-talking-api-key
AT_USERNAME=your-africas-talking-username

# Cloud Storage (for images)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
